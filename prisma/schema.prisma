generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  motto         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trip {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  location      String
  image         String
  accentColor   String         @default("#F5C842")
  status        String         @default("Upcoming")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  days          Day[]
  gourmetAwards GourmetAward[]
  packingItems  PackingItem[]
  tips          Tip[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  lat       Float
  lng       Float
  address   String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PackingItem {
  id       String  @id @default(cuid())
  tripId   String
  name     String
  category String  @default("Essential")
  isPacked Boolean @default(false)
  order    Int     @default(0)
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model GourmetAward {
  id       String  @id @default(cuid())
  tripId   String
  category String
  title    String
  comment  String?
  imageUrl String?
  eventId  String?
  order    Int     @default(0)
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Day {
  id        String   @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime
  title     String?
  highlight String?
  routeUrl  String?
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  events    Event[]

  @@unique([tripId, dayNumber])
}

model Event {
  id            String        @id @default(cuid())
  dayId         String
  time          String
  type          String
  title         String?
  desc          String?
  tag           String?
  tagLabel      String?
  locationUrl   String?
  foodName      String?
  foodDesc      String?
  highlight     String?
  isYatai       Boolean       @default(false)
  order         Int           @default(0)
  isConfirmed   Boolean       @default(false)
  isPending     Boolean       @default(false)
  actualExpense Int?          @default(0)
  actualTime    DateTime?
  notes         String?
  plannedBudget Int?          @default(0)
  status        String?
  day           Day           @relation(fields: [dayId], references: [id], onDelete: Cascade)
  photos        Media[]
  transitSteps  TransitStep[]
  yataiStops    YataiStop[]
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   @default("image")
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TransitStep {
  id         String  @id @default(cuid())
  eventId    String
  time       String
  station    String
  mode       String
  lineName   String?
  duration   String?
  fare       String?
  platform   String?
  exit       String?
  isTransfer Boolean @default(false)
  order      Int     @default(0)
  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model YataiStop {
  id          String  @id @default(cuid())
  eventId     String
  time        String
  stop        String
  desc        String
  order       Int     @default(0)
  isVisited   Boolean @default(false)
  liveStatus  String?
  waitMinutes Int?    @default(0)
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Tip {
  id          String  @id @default(cuid())
  tripId      String
  title       String
  body        String
  isWarning   Boolean @default(false)
  order       Int     @default(0)
  category    String? @default("General")
  deepLevel   Int     @default(1)
  imageUrl    String?
  isConfirmed Boolean @default(false)
  venue       String?
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
