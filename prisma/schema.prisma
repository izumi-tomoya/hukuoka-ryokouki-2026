// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  motto         String?   @db.Text
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trip {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  location    String
  image       String   // gradient or image url
  accentColor String   @default("#F5C842")
  status      String   @default("Upcoming") // Upcoming, Planning, Ongoing, Completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  days          Day[]
  tips          Tip[]
  packingItems  PackingItem[]
  gourmetAwards GourmetAward[]
}

model PackingItem {
  id        String  @id @default(cuid())
  tripId    String
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String
  category  String  @default("Essential") // Essential, Clothing, Gadget, Toiletries, Other
  isPacked  Boolean @default(false)
  order     Int     @default(0)
}

model GourmetAward {
  id        String  @id @default(cuid())
  tripId    String
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category  String  // e.g., "Best Ramen", "Best Street Food", "Most Romantic"
  title     String  // 店名や料理名
  comment   String? @db.Text
  imageUrl  String?
  eventId   String? // 紐付けるイベントID
  order     Int     @default(0)
}

model Day {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayNumber Int // 1, 2, 3...
  date      DateTime
  title     String?
  highlight String?
  routeUrl  String? // Google Maps Directions URL

  events Event[]

  @@unique([tripId, dayNumber])
}

model Event {
  id          String  @id @default(cuid())
  dayId       String
  day         Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  time        String
  type        String // transport, food, sightseeing, hotel, shopping, surprise, basic
  title       String?
  desc        String?
  tag         String?
  tagLabel    String?
  locationUrl String?
  foodName    String?
  foodDesc    String?
  highlight   String?
  isYatai     Boolean @default(false)
  isConfirmed Boolean @default(false)
  isPending   Boolean @default(false)
  order       Int     @default(0)

  // Live features
  status      String? // e.g., "Current", "Completed", "Next"
  actualTime  DateTime?
  
  // Memoir & Expense features
  notes         String?
  actualExpense Int?     @default(0)
  plannedBudget Int?     @default(0)
  
  // Relations
  photos       Media[]
  yataiStops   YataiStop[]
  transitSteps TransitStep[]
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   @default("image") // image, video
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TransitStep {
  id         String  @id @default(cuid())
  eventId    String
  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time       String
  station    String
  mode       String // walking, subway, train, bus, arrival
  lineName   String?
  duration   String?
  fare       String?
  platform   String?
  exit       String?
  isTransfer Boolean @default(false)
  order      Int     @default(0)
}

model YataiStop {
  id          String  @id @default(cuid())
  eventId     String
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time        String
  stop        String
  desc        String
  order       Int     @default(0)
  
  // Yatai Live features
  isVisited   Boolean @default(false)
  waitMinutes Int?    @default(0)
  liveStatus  String? // e.g., "Open", "Crowded", "Last Call"
}

model Tip {
  id        String  @id @default(cuid())
  tripId    String
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title     String
  body      String
  venue     String? // 店名・場所名
  imageUrl  String? // チケットのスクリーンショットなど
  isWarning Boolean @default(false)
  isConfirmed Boolean @default(false)
  order     Int     @default(0)
  
  // Deep Fukuoka features
  category  String? @default("General") // e.g., "Gourmet", "Hidden Gem", "2026 Trend"
  deepLevel Int     @default(1) // 1-5
}
